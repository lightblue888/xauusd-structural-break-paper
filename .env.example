# 环境变量配置示例 (复制成 .env 或在 shell 里 export/set)
# 公开复现者: 把发布的 CSV 放 ./data 即可, 大多数脚本无需设这些。
# 原作者本地: 按真实路径填下面几项。

# ---- 原始数据目录 (baseline 脚本读 V10/V11/1m CSV) ----
# Windows 示例: XAU_DATA_DIR=C:\path\to\raw_data
XAU_DATA_DIR=./data
# 可选: 覆盖默认文件名
# V10_CSV_NAME=v10_trades_raw.csv
# V11_OLD_CSV_NAME=v11_multiplier_applied.csv
# XAU_1M_CSV_NAME=xau_1m.csv

# ---- MT5 tester log 解析 (_parse_tester_log.py / _scan_log_sessions.py) ----
# MT5 终端目录 hash (Terminal/<HASH>/ 那一段)
MT5_HASH=YOUR_TERMINAL_HASH_HERE
# 或直接给完整 agent 日志目录 (优先级高于 MT5_HASH 拼出来的)
# MT5_TESTER_DIR=/path/to/MetaQuotes/Tester/<HASH>/Agent-127.0.0.1-3001/logs
# 单个日志文件 (_scan_log_sessions.py 用)
# MT5_LOG=/path/to/.../logs/YYYYMMDD.log

# ---- HistData 1m 增量合并 (_merge_1m_extended.py) ----
# HISTDATA_DIR=/path/to/histdata_extract
